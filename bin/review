#!/usr/bin/env bash

# Resolve the project root (follows symlinks)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # Resolve relative symlinks
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
REVIEW_TOOL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PORT="${REVIEW_PORT:-5200}"
LOG_DIR="$REVIEW_TOOL_DIR/logs"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/review-$(date +%Y%m%d-%H%M%S).log"

log() {
  echo "$@" | tee -a "$LOG_FILE"
}

usage() {
  echo "Usage: review <github-pr-url>"
  echo "       review https://github.com/owner/repo/pull/123"
  echo "       review --local [base-branch]"
  echo "       review --diff path/to/diff.patch"
  echo "       review --export <slug> [--output path.html] [--mode side-by-side|unified]"
  echo ""
  echo "Environment:"
  echo "  ANTHROPIC_API_KEY   Required. Your Anthropic API key."
  echo "  REVIEW_PORT         Dev server port (default: 5200)"
  echo ""
  echo "Logs are written to: $LOG_DIR/"
}

if [ -z "$1" ]; then
  usage
  exit 1
fi

ORIGINAL_CWD="$(pwd)"
cd "$REVIEW_TOOL_DIR"

# Handle --export: export a static HTML version of an existing walkthrough
if [ "$1" = "--export" ]; then
  shift
  log "$(date '+%Y-%m-%d %H:%M:%S') - export $*"
  node src/export-static.js "$@"
  exit $?
fi

log "$(date '+%Y-%m-%d %H:%M:%S') - review $*"
log "Generating walkthrough..."

# Run the generator, capturing output and exit code separately
# Pass original CWD so git fallback can find the local repo
set +e
output=$(REVIEW_ORIGINAL_CWD="$ORIGINAL_CWD" node src/generate.js "$@" 2>&1)
exit_code=$?
set -e

echo "$output"
echo "$output" >> "$LOG_FILE"

if [ $exit_code -ne 0 ]; then
  log ""
  log "Generation failed (exit code $exit_code). Log saved to: $LOG_FILE"
  exit $exit_code
fi

# Extract the slug from generator output
slug=$(echo "$output" | grep "^Slug: " | sed 's/^Slug: //')
if [ -z "$slug" ]; then
  slug="walkthrough-data"
fi

url="http://localhost:${PORT}/?pr=${slug}"

# Check if the dev server is already running
if command -v lsof >/dev/null 2>&1 && lsof -ti:$PORT >/dev/null 2>&1; then
  echo ""
  echo "Dev server already running. Opening: $url"
elif command -v ss >/dev/null 2>&1 && ss -tln "sport = :$PORT" | grep -q LISTEN; then
  echo ""
  echo "Dev server already running. Opening: $url"
else
  echo ""
  echo "Starting dev server..."
  pnpm vite --port $PORT &
  VITE_PID=$!
  sleep 2
  echo "Review tool running at $url (PID: $VITE_PID)"
fi

# Open browser (cross-platform)
if command -v open >/dev/null 2>&1; then
  open "$url"
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "$url"
elif command -v wslview >/dev/null 2>&1; then
  wslview "$url"
else
  echo "Open in your browser: $url"
fi

# If we started the server, wait for it
if [ -n "$VITE_PID" ]; then
  echo "Press Ctrl+C to stop the server."
  wait $VITE_PID
fi
